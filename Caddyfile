{
	# Let's Encrypt account email — used for issuing certs. Override via
	# CADDY_EMAIL in the compose env.
	email {$CADDY_EMAIL:admin@driftbase.dev}
}

{$CADDY_SITE:driftbase.dev} {
	encode gzip zstd

	# Control plane API + SSE. `flush_interval -1` disables response buffering
	# so /deployments/:id/logs streams in real time.
	@api path /api/*
	handle @api {
		reverse_proxy controlplane:8080 {
			flush_interval -1
		}
	}

	# Static SPA — fall through to index.html so TanStack Router owns paths.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

# Self-hosted Docker Registry fronted by Caddy so TLS is automatic. Auth is
# enforced by the control-plane auth proxy (see crates/controlplane/src/
# registry_proxy), which validates Basic auth against the credentials table
# and scopes access to the workspace id in the URL path before forwarding to
# the registry container.
{$REGISTRY_SITE:registry.driftbase.dev} {
	encode gzip zstd
	reverse_proxy controlplane:8080 {
		flush_interval -1
	}
}
