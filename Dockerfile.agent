# syntax=docker/dockerfile:1.6

FROM rust:1.94-slim-bookworm AS builder
WORKDIR /build
RUN apt-get update \
 && apt-get install -y --no-install-recommends pkg-config libssl-dev ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Copy the workspace source and build just the agent binary.
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates crates
RUN cargo build --release -p driftbase-agent \
 && strip target/release/driftbase-agent

FROM debian:bookworm-slim
# Runtime deps: ca-certs, git (for clone), docker CLI + buildx plugin (for
# building git services). The daemon itself runs on the host; we talk to it
# via the mounted /var/run/docker.sock.
ARG TARGETARCH
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg git \
  && install -m 0755 -d /etc/apt/keyrings \
  && curl -fsSL https://download.docker.com/linux/debian/gpg \
        | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
  && chmod a+r /etc/apt/keyrings/docker.gpg \
  && echo "deb [arch=${TARGETARCH} signed-by=/etc/apt/keyrings/docker.gpg] \
        https://download.docker.com/linux/debian bookworm stable" \
        > /etc/apt/sources.list.d/docker.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
        docker-ce-cli docker-buildx-plugin \
        iproute2 iptables wireguard-tools \
  && rm -rf /var/lib/apt/lists/*
# Railpack — used when a git service opts into `builder=railpack` instead of a
# hand-written Dockerfile. The install script drops a single statically-linked
# binary; BuildKit fetches the railpack frontend image on demand.
RUN curl -fsSL https://railpack.com/install.sh | bash -s -- -y -b /usr/local/bin \
  && apt-get purge -y --auto-remove gnupg curl \
  && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/driftbase-agent /usr/local/bin/driftbase-agent
ENTRYPOINT ["/usr/local/bin/driftbase-agent"]
