# syntax=docker/dockerfile:1.6

FROM rust:1.94-slim-bookworm AS builder
WORKDIR /build
RUN apt-get update \
 && apt-get install -y --no-install-recommends pkg-config libssl-dev ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Copy the workspace source and build just the agent binary.
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates crates
RUN cargo build --release -p driftbase-agent \
 && strip target/release/driftbase-agent

FROM debian:bookworm-slim
# Runtime deps: ca-certs, git (for clone), docker CLI + buildx plugin (for
# building git services). The daemon itself runs on the host; we talk to it
# via the mounted /var/run/docker.sock.
ARG TARGETARCH
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg git \
  && install -m 0755 -d /etc/apt/keyrings \
  && curl -fsSL https://download.docker.com/linux/debian/gpg \
        | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
  && chmod a+r /etc/apt/keyrings/docker.gpg \
  && echo "deb [arch=${TARGETARCH} signed-by=/etc/apt/keyrings/docker.gpg] \
        https://download.docker.com/linux/debian bookworm stable" \
        > /etc/apt/sources.list.d/docker.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
        docker-ce-cli docker-buildx-plugin \
        iproute2 iptables wireguard-tools \
  && rm -rf /var/lib/apt/lists/*
# Railpack — used when a git service opts into `builder=railpack` instead of a
# hand-written Dockerfile. Download a pinned release asset and verify it before
# installing so image builds do not execute a mutable remote installer script.
ARG RAILPACK_VERSION=0.23.0
RUN set -eux; \
  case "$TARGETARCH" in \
    amd64) railpack_target="x86_64-unknown-linux-musl"; railpack_sha="e8bffc181c13e68c1c78ec618f1418e60b1602ec548f3ec1054996394ce0f06a" ;; \
    arm64) railpack_target="arm64-unknown-linux-musl"; railpack_sha="d4505d0f5f9f48c6350ad349111e10a1f5ba16c118834c85c6d0ecd630b25c34" ;; \
    *) echo "unsupported TARGETARCH: $TARGETARCH" >&2; exit 1 ;; \
  esac; \
  curl -fsSLo /tmp/railpack.tar.gz \
    "https://github.com/railwayapp/railpack/releases/download/v${RAILPACK_VERSION}/railpack-v${RAILPACK_VERSION}-${railpack_target}.tar.gz"; \
  echo "${railpack_sha}  /tmp/railpack.tar.gz" | sha256sum -c -; \
  tar -xzf /tmp/railpack.tar.gz -C /usr/local/bin railpack; \
  chmod 0755 /usr/local/bin/railpack; \
  rm /tmp/railpack.tar.gz; \
  apt-get purge -y --auto-remove gnupg curl; \
  rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/driftbase-agent /usr/local/bin/driftbase-agent
ENTRYPOINT ["/usr/local/bin/driftbase-agent"]
