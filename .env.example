# Control plane
ZEDIZ_BIND_ADDR=0.0.0.0:8080
ZEDIZ_DATABASE_URL=postgres://zediz:zediz@localhost:5432/zediz
# 32 bytes, base64 — rotate via re-encrypt migration only. Generate with:
# openssl rand -base64 32
ZEDIZ_MASTER_KEY=
# URL the agent uses to reach the control plane (public)
ZEDIZ_PUBLIC_URL=http://localhost:8080
# Log level
RUST_LOG=info,zediz=debug,tower_http=debug

# --- Production (docker-compose) ---
# Public hostname for the web app + API. Caddy issues Let's Encrypt certs.
CADDY_SITE=zediz.dev
CADDY_EMAIL=admin@zediz.dev
# Public hostname for the self-hosted container registry (git-service builds
# push here). Before first `docker compose up registry`, generate the htpasswd
# file that the registry uses for basic auth:
#   docker run --rm httpd:2 htpasswd -Bbn <user> '<password>' > docker/registry-htpasswd
# Create a matching workspace credential (kind=registry) via the UI, with
# metadata={"url":"registry.zediz.dev","username":"<user>"} and the password
# as the secret.
REGISTRY_SITE=registry.zediz.dev
