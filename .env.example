# Control plane
DRIFTBASE_BIND_ADDR=0.0.0.0:8080
# Direct database URL. Used for migrations and as the runtime DB when no pooled URL is set.
DRIFTBASE_DATABASE_URL=postgres://driftbase:driftbase@localhost:5432/driftbase
# Optional pooled runtime database URL. Migrations still use DRIFTBASE_DATABASE_URL.
# DRIFTBASE_DATABASE_POOLED_URL=
# DATABASE_POOLED_URL is also accepted.
# 32 bytes, base64 — rotate via re-encrypt migration only. Generate with:
# openssl rand -base64 32
DRIFTBASE_MASTER_KEY=
# URL the agent uses to reach the control plane (public)
DRIFTBASE_PUBLIC_URL=http://localhost:8080
# Optional. Required for managed Hetzner workspaces, where users do not connect
# their own Hetzner account and Driftbase provisions from this local token.
DRIFTBASE_MANAGED_HETZNER_API_TOKEN=
# Optional. Preferred autoscaled Hetzner server type, e.g. cx22, cpx21, cax21.
# If a service needs more resources, Driftbase picks the cheapest larger fit.
DRIFTBASE_DEFAULT_HETZNER_SERVER_TYPE=
# Log level
RUST_LOG=info,driftbase=debug,tower_http=debug

# --- Production (docker-compose) ---
# Public hostname for the web app + API. Caddy issues Let's Encrypt certs.
CADDY_SITE=driftbase.app
CADDY_EMAIL=admin@driftbase.app
# Public hostname for the self-hosted container registry (git-service builds
# push here). The control plane fronts it with an auth proxy that validates
# basic auth against the credentials table and scopes access by workspace id.
# Add a workspace "registry" credential in the UI (kind=registry, URL = this
# host, password of your choice) — the UI surfaces a per-credential ULID that
# becomes the docker-login username.
REGISTRY_SITE=registry.driftbase.app
# The CP uses this upstream URL to reach the registry container on the shared
# docker network. Override only if you run the registry service elsewhere.
DRIFTBASE_REGISTRY_UPSTREAM=http://registry:5000
# Host path where the bundled registry stores image blobs on the filesystem
# backend (default). Prefer an absolute path in production, e.g.
# /var/lib/driftbase/registry. Ignored when S3 is active (see below) but the
# host directory is still mounted so flipping back is non-destructive.
REGISTRY_STORAGE_PATH=./data/registry

# --- Bundled registry storage: S3 (optional) ---
# Set REGISTRY_STORAGE_S3_BUCKET to switch the bundled registry from local
# filesystem to an S3-compatible bucket. Works with AWS S3, Hetzner Object
# Storage, Cloudflare R2, MinIO, Backblaze B2. Leave the bucket blank to keep
# the filesystem backend.
REGISTRY_STORAGE_S3_BUCKET=
# Region the bucket lives in. AWS-style strings, e.g. us-east-1, eu-central-1.
# Use "auto" for Cloudflare R2. Required when S3 is active.
REGISTRY_STORAGE_S3_REGION=
# Custom endpoint for non-AWS providers. Examples:
#   Hetzner: https://fsn1.your-objectstorage.com (also nbg1 / hel1)
#   R2:      https://<account-id>.r2.cloudflarestorage.com
#   MinIO:   http://minio:9000
# Leave blank when talking to AWS S3 directly.
REGISTRY_STORAGE_S3_REGIONENDPOINT=
# Access key / secret key. Omit on AWS hosts that have an instance role.
REGISTRY_STORAGE_S3_ACCESSKEY=
REGISTRY_STORAGE_S3_SECRETKEY=
# Path-style URLs are required by most non-AWS S3-compatible providers.
# Only set to false when talking to AWS S3 directly.
REGISTRY_STORAGE_S3_FORCEPATHSTYLE=true
# Force HTTPS to the S3 endpoint. Only set to false for local MinIO over plain HTTP.
REGISTRY_STORAGE_S3_SECURE=true
# Optional key prefix inside the bucket if you want to share it with other data.
REGISTRY_STORAGE_S3_ROOTDIRECTORY=
